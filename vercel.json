{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/success", "dest": "/success.html" },
    { "src": "/(.*\\.(jpg|jpeg|png|gif|ico|css|js))", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
